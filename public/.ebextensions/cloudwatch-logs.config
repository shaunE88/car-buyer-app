commands:
  01_download_cloudwatch_agent:
    command: "wget https://s3.amazonaws.com/amazoncloudwatch-agent/amazon_linux/amd64/latest/amazon-cloudwatch-agent.rpm -O /tmp/amazon-cloudwatch-agent.rpm"
  02_install_cloudwatch_agent:
    command: "rpm -U /tmp/amazon-cloudwatch-agent.rpm"
  03_create_config:
    command: |
      cat > /opt/aws/amazon-cloudwatch-agent/etc/amazon-cloudwatch-agent.json << 'EOF'
      {
        "logs": {
          "logs_collected": {
            "files": {
              "collect_list": [
                {
                  "file_path": "/var/log/nginx/access.log",
                  "log_group_name": "/aws/elasticbeanstalk/car-buyer-app-env/nginx/access.log",
                  "log_stream_name": "{instance_id}"
                },
                {
                  "file_path": "/var/log/nginx/error.log",
                  "log_group_name": "/aws/elasticbeanstalk/car-buyer-app-env/nginx/error.log",
                  "log_stream_name": "{instance_id}"
                }
              ]
            }
          }
        }
      }
      EOF
  04_start_cloudwatch_agent:
    command: "/opt/aws/amazon-cloudwatch-agent/bin/amazon-cloudwatch-agent-ctl -a fetch-config -m ec2 -s -c file:/opt/aws/amazon-cloudwatch-agent/etc/amazon-cloudwatch-agent.json"